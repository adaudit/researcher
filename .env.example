# Application
APP_ENV=development
SECRET_KEY=change-me-in-production
API_V1_PREFIX=/v1

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://researcher:researcher_dev@localhost:5432/researcher
DATABASE_URL_SYNC=postgresql://researcher:researcher_dev@localhost:5432/researcher

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Object Storage (S3-compatible)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_ARTIFACTS=researcher-artifacts
S3_BUCKET_MEDIA=researcher-media
S3_REGION=us-east-1

# Hindsight
HINDSIGHT_API_KEY=your-hindsight-api-key
HINDSIGHT_BASE_URL=https://api.hindsight.dev

# LLM Providers (at least one required)
ANTHROPIC_API_KEY=your-anthropic-api-key   # Opus for creative writing ($15/$75 per M)
GOOGLE_API_KEY=your-google-api-key         # Flash for multimodal + long docs ($0.15/$0.60 per M)
OPENAI_API_KEY=your-openai-api-key         # Optional fallback

# Z.ai — GLM-5.1 for cheap reasoning ($0.95/$3.15 per M, #1 SWE-Bench)
ZAI_API_KEY=
ZAI_BASE_URL=https://open.z.ai/api/paas/v4
ZAI_MODEL=glm-5.1

# Local LLM — Gemma 4 26B via Ollama for $0 extraction/classification
# Install: ollama pull gemma4:26b
# Start: ollama serve (exposes OpenAI-compatible API at localhost:11434)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=gemma4:26b

# External APIs
META_AD_LIBRARY_ACCESS_TOKEN=
NCBI_API_KEY=

# Acquisition — ScrapCreators (social platform data: TikTok, YouTube, Reddit, Meta, etc.)
SCRAPECREATORS_API_KEY=
SCRAPECREATORS_BASE_URL=https://api.scrapecreators.com/v1
